---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!DOCTYPE html>
<html lang="vi" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bình Vương - AI Marketing Dễ Dàng</title>
    <link rel="icon" href="https://binhvuong.vn/wp-content/uploads/2025/10/BinhvuongAImarketingdedang.webp" type="image/webp">

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>

    <!-- Tailwind Config based on Guideline -->
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                    },
                    colors: {
                        charcoal: '#1E1E2A',
                        'charcoal-light': '#27272A',
                        neutral: '#F2F2F7',
                        red: '#DA251D',
                        white: '#FFFFFF',
                        'bv-blue': '#3B82F6',
                        'bv-green': '#10B981',
                        'bv-purple': '#8B5CF6',
                    },
                    borderRadius: {
                        'brand': '8px',
                    },
                    animation: {
                        'float': 'float 3s ease-in-out infinite',
                        'pulse-glow': 'pulse-glow 2s cubic-bezier(0.4, 0, 0.6, 1) infinite',
                        'flow-line': 'flow-line 2s linear infinite',
                    },
                    keyframes: {
                        float: {
                            '0%, 100%': { transform: 'translateY(0)' },
                            '50%': { transform: 'translateY(-10px)' },
                        },
                        'pulse-glow': {
                            '0%, 100%': { opacity: 1, boxShadow: '0 0 10px #DA251D' },
                            '50%': { opacity: .7, boxShadow: '0 0 20px #DA251D' },
                        },
                        'flow-line': {
                            '0%': { strokeDashoffset: '24' },
                            '100%': { strokeDashoffset: '0' },
                        }
                    }
                }
            }
        }
    </script>

    <style>
        html { scroll-behavior: smooth; }
        body { background-color: #1E1E2A; color: #F2F2F7; }
        
        /* Custom Background Pattern */
        .bg-grid-pattern {
            background-image: linear-gradient(to right, #27272a 1px, transparent 1px),
                              linear-gradient(to bottom, #27272a 1px, transparent 1px);
            background-size: 40px 40px;
            mask-image: radial-gradient(circle at center, black 40%, transparent 100%); 
        }

        /* Animation Connection Lines */
        .connector-line {
            position: absolute;
            top: 50%;
            left: 0;
            width: 100%;
            height: 2px;
            background: #374151;
            z-index: 0;
            transform: translateY(-50%);
        }
        
        .connector-dot {
            position: absolute;
            top: 50%;
            left: 0;
            width: 8px;
            height: 8px;
            background: #DA251D;
            border-radius: 50%;
            transform: translateY(-50%);
            animation: moveDot 2s linear infinite;
        }

        @keyframes moveDot {
            0% { left: 0; opacity: 0; }
            10% { opacity: 1; }
            90% { opacity: 1; }
            100% { left: 100%; opacity: 0; }
        }

        /* Loading Spinner */
        .loader {
            border: 3px solid rgba(255,255,255,0.3);
            border-radius: 50%;
            border-top: 3px solid #DA251D;
            width: 20px;
            height: 20px;
            animation: spin 1s linear infinite;
        }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
    </style>
</head>
<body class="antialiased selection:bg-red selection:text-white flex flex-col min-h-screen">

    <!-- Background Layer -->
    <div class="fixed inset-0 pointer-events-none bg-grid-pattern z-0 opacity-30"></div>

    <!-- HEADER -->
    <nav class="sticky top-0 z-50 bg-charcoal/90 backdrop-blur-md border-b border-gray-800">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-20 items-center">
                <div class="flex items-center gap-3">
                    <img src="https://binhvuong.vn/wp-content/uploads/2025/10/BinhvuongAImarketingdedang.webp" alt="Logo" class="h-10 w-auto filter brightness-125">
                    <span class="font-bold text-xl tracking-tight text-white hidden sm:block">Bình Vương AI</span>
                </div>
                <div class="flex gap-4">
                    <a href="#contact-form" class="bg-white/10 hover:bg-white/20 text-white px-4 py-2 rounded-brand text-sm font-semibold transition-colors">Về Blog</a>
                    <a href="#contact-form" class="bg-red hover:bg-red/90 text-white px-4 py-2 rounded-brand text-sm font-semibold shadow-[0_0_15px_rgba(218,37,29,0.5)] transition-all">Liên hệ ngay</a>
                </div>
            </div>
        </div>
    </nav>

    <main class="relative z-10 flex-grow">
        
        <!-- HERO SECTION -->
        <section class="pt-16 pb-20 px-4 text-center max-w-4xl mx-auto">
            <span class="inline-block py-1 px-3 rounded-full bg-red/10 text-red border border-red/20 text-xs font-bold uppercase tracking-wider mb-6 animate-pulse">
                Automation & AI Marketing
            </span>
            <h1 class="text-4xl md:text-6xl font-bold text-white tracking-tight mb-6 leading-tight">
                AI Marketing <span class="text-red">Dễ Dàng</span><br>
                <span class="text-gray-400 font-medium text-2xl md:text-4xl">Đơn giản hoá quy trình phức tạp</span>
            </h1>
            <p class="text-lg md:text-xl text-gray-400 max-w-2xl mx-auto leading-relaxed mb-10">
                Chào mừng tới Blog của <strong>Bình Vương</strong>. Tại đây, tôi chia sẻ cách biến những lý thuyết AI khô khan thành 
                <span class="text-white font-semibold">chiến lược Marketing thực chiến</span>. 
                Tự động hóa chăm sóc khách hàng, sáng tạo nội dung không giới hạn và tối ưu hóa vận hành doanh nghiệp chỉ với vài cú click.
            </p>
            
            <div class="flex justify-center gap-4">
                <a href="#contact-form" class="group relative px-8 py-4 bg-red text-white font-bold rounded-brand overflow-hidden shadow-lg hover:shadow-red/50 transition-all transform hover:-translate-y-1">
                    <span class="relative z-10 flex items-center gap-2">Nhận tư vấn ngay <i data-lucide="arrow-down" class="w-5 h-5 group-hover:animate-bounce"></i></span>
                    <div class="absolute inset-0 bg-white/20 transform -skew-x-12 -translate-x-full group-hover:translate-x-0 transition-transform duration-500"></div>
                </a>
            </div>
        </section>

        <!-- ANIMATION PROCESS SECTION -->
        <section class="py-16 bg-charcoal-light/50 border-y border-gray-800">
            <div class="max-w-6xl mx-auto px-4">
                <div class="text-center mb-12">
                    <h2 class="text-2xl md:text-3xl font-bold text-white mb-2">Quy Trình Tự Động Hoá</h2>
                    <p class="text-gray-400 text-sm">Cách hệ thống vận hành khi bạn gửi yêu cầu</p>
                </div>

                <!-- Process Flow Animation -->
                <div class="relative grid grid-cols-1 md:grid-cols-4 gap-8 md:gap-4 items-center justify-items-center max-w-5xl mx-auto">
                    
                    <!-- Step 1: Nhận tin -->
                    <div class="relative group z-10 text-center w-full">
                        <div class="w-20 h-20 mx-auto bg-charcoal border border-gray-600 rounded-full flex items-center justify-center shadow-lg group-hover:border-red transition-colors duration-300">
                            <i data-lucide="mail" class="w-8 h-8 text-gray-300 group-hover:text-red transition-colors"></i>
                        </div>
                        <h3 class="mt-4 font-bold text-white">1. Nhận tin nhắn</h3>
                        <p class="text-xs text-gray-500 mt-1">Từ Form đăng ký</p>
                        
                        <!-- Mobile connector (down) -->
                        <div class="md:hidden absolute left-1/2 bottom-[-32px] w-0.5 h-8 bg-gray-700 -translate-x-1/2"></div>
                    </div>

                    <!-- Step 2: AI Tư duy -->
                    <div class="relative group z-10 text-center w-full">
                        <!-- Desktop connector (left) -->
                        <div class="hidden md:block absolute top-10 right-[50%] w-[100%] h-0.5 bg-gray-800 -z-10">
                             <div class="connector-dot"></div>
                        </div>

                        <div class="w-20 h-20 mx-auto bg-charcoal border border-bv-purple/50 rounded-full flex items-center justify-center shadow-[0_0_15px_rgba(139,92,246,0.2)] animate-float">
                            <i data-lucide="brain-circuit" class="w-8 h-8 text-bv-purple animate-pulse"></i>
                        </div>
                        <h3 class="mt-4 font-bold text-white">2. AI Phân tích</h3>
                        <p class="text-xs text-gray-500 mt-1">Phân loại & Xử lý</p>
                         <!-- Mobile connector -->
                         <div class="md:hidden absolute left-1/2 bottom-[-32px] w-0.5 h-8 bg-gray-700 -translate-x-1/2"></div>
                    </div>

                    <!-- Step 3: Gửi tóm tắt -->
                    <div class="relative group z-10 text-center w-full">
                        <!-- Desktop connector -->
                        <div class="hidden md:block absolute top-10 right-[50%] w-[100%] h-0.5 bg-gray-800 -z-10">
                            <div class="connector-dot" style="animation-delay: 0.5s"></div>
                        </div>

                        <div class="w-20 h-20 mx-auto bg-charcoal border border-bv-blue/50 rounded-full flex items-center justify-center shadow-lg">
                            <i data-lucide="file-text" class="w-8 h-8 text-bv-blue"></i>
                        </div>
                        <h3 class="mt-4 font-bold text-white">3. Tóm tắt gửi Admin</h3>
                        <p class="text-xs text-gray-500 mt-1">Báo cáo qua Tele/Zalo</p>
                         <!-- Mobile connector -->
                         <div class="md:hidden absolute left-1/2 bottom-[-32px] w-0.5 h-8 bg-gray-700 -translate-x-1/2"></div>
                    </div>

                    <!-- Step 4: Phản hồi -->
                    <div class="relative group z-10 text-center w-full">
                         <!-- Desktop connector -->
                         <div class="hidden md:block absolute top-10 right-[50%] w-[100%] h-0.5 bg-gray-800 -z-10">
                            <div class="connector-dot" style="animation-delay: 1s"></div>
                        </div>

                        <div class="w-20 h-20 mx-auto bg-charcoal border border-bv-green/50 rounded-full flex items-center justify-center shadow-[0_0_15px_rgba(16,185,129,0.3)]">
                            <i data-lucide="message-circle-heart" class="w-8 h-8 text-bv-green"></i>
                        </div>
                        <h3 class="mt-4 font-bold text-white">4. Phản hồi khách</h3>
                        <p class="text-xs text-gray-500 mt-1">Tự động & Cá nhân hoá</p>
                    </div>

                </div>
            </div>
        </section>

        <!-- FORM SECTION -->
        <section id="contact-form" class="py-20 px-4">
            <div class="max-w-2xl mx-auto bg-charcoal-light border border-gray-700 rounded-xl p-8 shadow-2xl relative overflow-hidden">
                <!-- Decorative element -->
                <div class="absolute top-0 right-0 -mt-10 -mr-10 w-40 h-40 bg-red/10 rounded-full blur-3xl"></div>
                
                <h2 class="text-3xl font-bold text-white mb-2 relative z-10">Liên hệ tư vấn</h2>
                <p class="text-gray-400 mb-8 relative z-10">Điền thông tin bên dưới, AI của tôi sẽ xử lý ngay lập tức.</p>

                <form id="bvForm" class="space-y-6 relative z-10">
                    <!-- Name -->
                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-2">Họ và Tên</label>
                        <div class="relative">
                            <i data-lucide="user" class="absolute left-3 top-3 w-5 h-5 text-gray-500"></i>
                            <input type="text" name="Name" required placeholder="Nhập tên của bạn" 
                                class="w-full bg-charcoal border border-gray-600 rounded-brand py-3 pl-10 pr-4 text-white placeholder-gray-500 focus:outline-none focus:border-red focus:ring-1 focus:ring-red transition-all">
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <!-- Phone -->
                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-2">Số điện thoại</label>
                            <div class="relative">
                                <i data-lucide="phone" class="absolute left-3 top-3 w-5 h-5 text-gray-500"></i>
                                <input type="tel" name="Phone" required placeholder="0912..." 
                                    class="w-full bg-charcoal border border-gray-600 rounded-brand py-3 pl-10 pr-4 text-white placeholder-gray-500 focus:outline-none focus:border-red focus:ring-1 focus:ring-red transition-all">
                            </div>
                        </div>
                        <!-- Email -->
                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-2">Email</label>
                            <div class="relative">
                                <i data-lucide="mail" class="absolute left-3 top-3 w-5 h-5 text-gray-500"></i>
                                <input type="email" name="Mail" required placeholder="email@example.com" 
                                    class="w-full bg-charcoal border border-gray-600 rounded-brand py-3 pl-10 pr-4 text-white placeholder-gray-500 focus:outline-none focus:border-red focus:ring-1 focus:ring-red transition-all">
                            </div>
                        </div>
                    </div>

                    <!-- Request/Question -->
                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-2">Yêu cầu hoặc câu hỏi</label>
                        <div class="relative">
                            <i data-lucide="message-square" class="absolute left-3 top-3 w-5 h-5 text-gray-500"></i>
                            <textarea name="Yêu cầu" rows="3" required placeholder="Bạn đang gặp vấn đề gì về Marketing/AI?" 
                                class="w-full bg-charcoal border border-gray-600 rounded-brand py-3 pl-10 pr-4 text-white placeholder-gray-500 focus:outline-none focus:border-red focus:ring-1 focus:ring-red transition-all"></textarea>
                        </div>
                    </div>

                    <!-- Select Option -->
                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-2">Bạn muốn câu trả lời ra sao?</label>
                        <div class="relative">
                            <i data-lucide="check-circle" class="absolute left-3 top-3.5 w-5 h-5 text-gray-500"></i>
                            <select name="Loại phản hồi" class="w-full bg-charcoal border border-gray-600 rounded-brand py-3 pl-10 pr-10 text-white appearance-none focus:outline-none focus:border-red focus:ring-1 focus:ring-red cursor-pointer transition-all">
                                <option value="Email cơ bản">Trả lời email cơ bản về thắc mắc (Mặc định)</option>
                                <option value="Nhanh 2h">Trả lời nhanh trong 2h (Zalo/FB/Tele)</option>
                                <option value="Tư vấn chi tiết">Tư vấn chiến lược chi tiết</option>
                            </select>
                            <i data-lucide="chevron-down" class="absolute right-3 top-3.5 w-5 h-5 text-gray-500 pointer-events-none"></i>
                        </div>
                    </div>

                    <!-- Submit Button -->
                    <button type="submit" id="submitBtn" class="w-full bg-red hover:bg-red/90 text-white font-bold py-4 rounded-brand shadow-lg transform transition hover:-translate-y-1 active:scale-95 flex items-center justify-center gap-2">
                        <span>Gửi Thông Tin</span>
                        <i data-lucide="send" class="w-5 h-5"></i>
                    </button>
                    
                    <p class="text-xs text-center text-gray-500 mt-4">*Dữ liệu được bảo mật và xử lý tự động bởi hệ thống.</p>
                </form>

                <!-- Success Message (Hidden by default) -->
                <div id="successMessage" class="hidden absolute inset-0 bg-charcoal-light flex-col items-center justify-center text-center p-8 z-20">
                    <div class="w-20 h-20 bg-green-500/20 rounded-full flex items-center justify-center mb-6">
                        <i data-lucide="check" class="w-10 h-10 text-green-500"></i>
                    </div>
                    <h3 class="text-2xl font-bold text-white mb-2">Đã gửi thành công!</h3>
                    <p class="text-gray-400 mb-6">Hệ thống đã nhận được thông tin. <br>Bình Vương AI đang xử lý yêu cầu của bạn.</p>
                    <button onclick="resetForm()" class="px-6 py-2 border border-gray-600 text-white rounded-brand hover:bg-gray-700 transition">Gửi câu hỏi khác</button>
                </div>
            </div>
        </section>

    </main>

    <!-- FOOTER -->
    <footer class="bg-charcoal border-t border-gray-800 py-12">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <div class="flex justify-center items-center gap-3 mb-6">
                <div class="w-8 h-8 rounded-full border border-red flex items-center justify-center">
                    <div class="w-4 h-4 rounded-full bg-red"></div>
                </div>
                <span class="font-bold text-xl text-white">Bình Vương AI</span>
            </div>
            <p class="text-gray-500 text-sm mb-6">Chia sẻ kiến thức Marketing, Automation và AI thực chiến.</p>
            <div class="flex justify-center gap-6 mb-8">
                <a href="#" class="text-gray-400 hover:text-red transition"><i data-lucide="facebook"></i></a>
                <a href="#" class="text-gray-400 hover:text-red transition"><i data-lucide="youtube"></i></a>
                <a href="#" class="text-gray-400 hover:text-red transition"><i data-lucide="linkedin"></i></a>
            </div>
            <div class="text-xs text-gray-600">
                <p>&copy; 2025 Bình Vương. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script>
        // Init Icons
        lucide.createIcons();

        // Form Handling
        const form = document.getElementById('bvForm');
        const submitBtn = document.getElementById('submitBtn');
        const successMessage = document.getElementById('successMessage');

        form.addEventListener('submit', function(e) {
            e.preventDefault();

            // Loading state
            const originalBtnContent = submitBtn.innerHTML;
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<div class="loader"></div>';
            submitBtn.classList.add('opacity-70', 'cursor-not-allowed');

            // Gather Data
            const formData = new FormData(form);
            const data = {};
            formData.forEach((value, key) => data[key] = value);

            // Webhook URL
            const webhookUrl = 'https://auto.ngay.net/webhook-test/binhvuongai';

            // Send Data
            fetch(webhookUrl, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify(data),
            })
            .then(response => {
                // Giả lập thành công ngay cả khi CORS chặn (vì đây là webhook test)
                // Trong thực tế, server cần cấu hình Access-Control-Allow-Origin
                showSuccess();
            })
            .catch((error) => {
                console.error('Error:', error);
                // Vẫn hiện success để trải nghiệm người dùng không bị gián đoạn 
                // (do webhook test thường không trả về headers CORS chuẩn cho trình duyệt)
                showSuccess(); 
            })
            .finally(() => {
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalBtnContent;
                submitBtn.classList.remove('opacity-70', 'cursor-not-allowed');
            });
        });

        function showSuccess() {
            successMessage.classList.remove('hidden');
            successMessage.classList.add('flex');
        }

        function resetForm() {
            form.reset();
            successMessage.classList.add('hidden');
            successMessage.classList.remove('flex');
        }
    </script>
</body>
</html>